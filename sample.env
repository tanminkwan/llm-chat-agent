# OIDC / IDP Configuration
OIDC_ISSUER=https://idp.mwm.local:20443
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=https://llm-agent.mwm.local:21443/auth/callback

# LLM Configuration (OpenAI-compatible)
# For vLLM, set BASE_URL to your vLLM server (e.g., http://localhost:8000/v1)
# For OpenAI, leave BASE_URL empty or set to https://api.openai.com/v1

CHAT_LLM_BASE_URL=
CHAT_LLM_MODEL=gpt-4o
CHAT_LLM_LABEL=일반 대화
CHAT_LLM_API_KEY=
CHAT_LLM_USE_TEMPERATURE=true

REASONING_LLM_BASE_URL=
REASONING_LLM_MODEL=o4-mini
REASONING_LLM_LABEL=심층 추론
REASONING_LLM_API_KEY=
REASONING_LLM_USE_TEMPERATURE=false

EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_DIM=1536

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Database Configuration
DATABASE_URL=postgresql+asyncpg://admin:password@db:5432/llm_agent

# App Configuration
APP_NAME="리발소(VER:20260421.001)"
DEBUG=true
LOG_LEVEL=INFO
MEMORY_MAX_MESSAGES=10

# --- Phase 06: Observability (Loki + Promtail + Grafana) ---
# Loki 보관 기간 (Go duration). 30일=720h, 14일=336h
LOKI_RETENTION_PERIOD=720h

# Grafana 외부 접근 URL.
# - 사용자 브라우저가 실제로 접근하는 FQDN 과 정확히 같아야 한다.
#   (그렇지 않으면 Grafana 가 정적 자산/리다이렉트/OIDC redirect_uri 경로를 잘못 만든다.)
# - trailing slash 없이 작성 (Loki derived field URL 이 ${GF_SERVER_ROOT_URL}/d/... 형태라 // 방지)
# - 개발 (host alias)   : https://grafana.mwm.local:21443
# - 운영(production)    : https://<운영 도메인>     (TLS 정상 도메인 사용)
# - sub-path 로 노출하려면 GF_SERVER_SERVE_FROM_SUB_PATH=true 와 nginx 설정도 함께 변경 필요.
GRAFANA_ROOT_URL=https://grafana.mwm.local:21443

# Grafana 임시 admin 로그인 비밀번호 (운영 전 반드시 변경)
GRAFANA_ADMIN_PASSWORD=changeme

# --- Phase 06.1: Grafana ↔ mwm-idp OIDC SSO ---
# IDP(/home/hennry/GitHub/mw/mw_app/idp) 에 아래 client_id/secret/redirect_uri 그대로 등록
GRAFANA_OIDC_CLIENT_ID=grafana-client
GRAFANA_OIDC_CLIENT_SECRET=8sZ4fK2pN7vM3xL9qR6tY1bH5dW0jA8e
GRAFANA_OIDC_AUTH_URL=https://idp.mwm.local:20443/oauth/authorize
GRAFANA_OIDC_TOKEN_URL=https://idp.mwm.local:20443/oauth/token
# 주의: mwm-idp의 userinfo는 /api/userinfo (Discovery 응답과 동일)
GRAFANA_OIDC_API_URL=https://idp.mwm.local:20443/api/userinfo
GRAFANA_OIDC_LOGOUT_URL=https://idp.mwm.local:20443/logout
GRAFANA_ALLOWED_GROUPS=Admin,PowerUser,User

# --- Phase 07: Tool Lab (LLM Tool Calling Simulator) ---
# 메뉴/엔드포인트 전체 on/off. false 면 라우터 자체가 등록되지 않음.
TOOLLAB_ENABLED=true
# Tool Lab 진입 가능 OIDC 그룹(콤마 구분). User 도 자기 도구 등록·실행 가능;
# system(seed) 도구 편집/삭제는 routers/toollab._load_owned 에서 Admin 만 허용.
TOOLLAB_ALLOWED_GROUPS=Admin,User
# 단일 핸들러 호출 wall-clock 타임아웃(ms).
TOOLLAB_HANDLER_TIMEOUT_MS=2000
# 단일 run 의 LLM↔tool 루프 turn 상한 (request 별 override 가능).
TOOLLAB_MAX_TOOL_ITERATIONS=8
# request 가 override 해도 넘지 못하는 hard cap.
TOOLLAB_MAX_TOOL_ITERATIONS_HARD=16
# 한 run 에 노출 가능한 도구 수 상한 (스키마 비대화 방지).
TOOLLAB_MAX_TOOLS_PER_RUN=32
# 핸들러 동시 실행용 스레드풀 크기.
TOOLLAB_HANDLER_THREADPOOL_SIZE=4

# vLLM 의 --tool-call-parser 라벨링 (검증/주입 X — 그대로 LLM_LOG / 트레이스에 흘림).
# hosted OpenAI 면 빈 문자열로 두면 된다.
# 서빙 매트릭스 (docs/P07_요구사항.md §4.3.1):
#   - vLLM + gpt-oss-*               → openai
#   - vLLM + Qwen3-Coder-*           → qwen3_coder
#   - vLLM + Qwen3-Instruct / Qwen2.5 → hermes
#   - vLLM + Llama-3.x-Instruct      → llama3_json
#   - vLLM + Mistral-Instruct        → mistral
CHAT_LLM_TOOL_PARSER=
REASONING_LLM_TOOL_PARSER=
