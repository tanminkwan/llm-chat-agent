{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "검색 알고리즘별 호출 비율",
      "type": "piechart",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list" }, "pieType": "donut" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (search_method) (count_over_time({container=\"llm-agent\", type=\"rag_search_request\"}[$__range]))",
          "legendFormat": "{{search_method}}",
          "datasource": { "type": "loki", "uid": "loki" },
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "title": "결과 0건 비율 (%)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 30 } ] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(count_over_time({container=\"llm-agent\", type=\"rag_search_response\"} | json | results_count = \"0\" [$__range])) / clamp_min(sum(count_over_time({container=\"llm-agent\", type=\"rag_search_response\"}[$__range])), 1)) * 100",
          "legendFormat": "zero-result %",
          "datasource": { "type": "loki", "uid": "loki" },
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "평균 RAG 지연 (ms)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 } ] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time({container=\"llm-agent\", type=\"rag_search_response\"} | json | unwrap latency_ms [5m])",
          "legendFormat": "avg latency",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ]
    },
    {
      "id": 4,
      "title": "평균 top-1 score 추이 (vector 검색)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "min": 0, "max": 1, "unit": "none" },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time({container=\"llm-agent\", type=\"rag_search_response\", search_method=\"vector\"} | json | top_score != \"\" | unwrap top_score [5m])",
          "legendFormat": "avg top_score",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ]
    },
    {
      "id": 5,
      "title": "RAG 검색 요청 수 (알고리즘별)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "bars", "fillOpacity": 60 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (search_method) (count_over_time({container=\"llm-agent\", type=\"rag_search_request\"}[1m]))",
          "legendFormat": "{{search_method}}",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ]
    },
    {
      "id": 6,
      "title": "최근 RAG 검색 (raw)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [
        {
          "refId": "A",
          "expr": "{container=\"llm-agent\", type=~\"rag_search_request|rag_search_response\"}",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
